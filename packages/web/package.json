{
  "name": "@warabi1062/skillsmith-viewer",
  "version": "0.0.0",
  "type": "module",
  "description": "SkillSmith の Web ビューアー。プラグイン定義の閲覧とオーケストレーター構造の可視化を提供する",
  "keywords": [
    "claude",
    "claude-code",
    "skill",
    "plugin",
    "viewer",
    "web"
  ],
  "author": "warabi1062 <kohei.2126@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/warabi1062/SkillSmith.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/warabi1062/SkillSmith#readme",
  "bugs": {
    "url": "https://github.com/warabi1062/SkillSmith/issues"
  },
  "exports": {
    "./server": {
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "vite build && tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@warabi1062/skillsmith-core": "workspace:*",
    "express": "^5.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "vite": "^8.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
