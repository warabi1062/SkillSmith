{
  "name": "@warabi1062/skillsmith-core",
  "version": "1.0.3",
  "type": "module",
  "description": "SkillSmith のコア生成エンジン。プラグイン定義の読み込み・スキル生成・ファイル出力を提供する",
  "keywords": [
    "claude",
    "claude-code",
    "skill",
    "plugin",
    "generator",
    "core"
  ],
  "author": "warabi1062 <kohei.2126@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/warabi1062/SkillSmith.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/warabi1062/SkillSmith#readme",
  "bugs": {
    "url": "https://github.com/warabi1062/SkillSmith/issues"
  },
  "exports": {
    "./types": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/types/index.cjs"
      }
    },
    "./types/constants": {
      "import": {
        "types": "./dist/types/constants.d.ts",
        "default": "./dist/types/constants.js"
      },
      "require": {
        "types": "./dist/types/constants.d.cts",
        "default": "./dist/types/constants.cjs"
      }
    },
    "./generator": {
      "import": {
        "types": "./dist/generator/index.d.ts",
        "default": "./dist/generator/index.js"
      },
      "require": {
        "types": "./dist/generator/index.d.cts",
        "default": "./dist/generator/index.cjs"
      }
    },
    "./generator/types": {
      "import": {
        "types": "./dist/generator/types.d.ts",
        "default": "./dist/generator/types.js"
      },
      "require": {
        "types": "./dist/generator/types.d.cts",
        "default": "./dist/generator/types.cjs"
      }
    },
    "./exporter": {
      "import": {
        "types": "./dist/exporter/index.d.ts",
        "default": "./dist/exporter/index.js"
      },
      "require": {
        "types": "./dist/exporter/index.d.cts",
        "default": "./dist/exporter/index.cjs"
      }
    },
    "./loader": {
      "import": {
        "types": "./dist/loader/index.d.ts",
        "default": "./dist/loader/index.js"
      },
      "require": {
        "types": "./dist/loader/index.d.cts",
        "default": "./dist/loader/index.cjs"
      }
    },
    "./utils/skill-type": {
      "import": {
        "types": "./dist/utils/skill-type.d.ts",
        "default": "./dist/utils/skill-type.js"
      },
      "require": {
        "types": "./dist/utils/skill-type.d.cts",
        "default": "./dist/utils/skill-type.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "jiti": "^2.6.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
