generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum ComponentType {
  SKILL
}

enum SkillType {
  ENTRY_POINT
  WORKER
  WORKER_WITH_SUB_AGENT
  WORKER_WITH_AGENT_TEAM
}

enum ComponentFileRole {
  TEMPLATE
  REFERENCE
  EXAMPLE
}

model Plugin {
  id          String      @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  components  Component[]
}

model Component {
  id        String        @id @default(cuid())
  pluginId  String
  type      ComponentType
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  plugin           Plugin                @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  skillConfig      SkillConfig?
  files            ComponentFile[]
  dependenciesFrom   ComponentDependency[] @relation("DependencySource")
  dependenciesTo     ComponentDependency[] @relation("DependencyTarget")
  teamMemberships    AgentTeamMember[]     @relation("MemberComponent")
  agentTeamMembers   AgentTeamMember[]     @relation("AgentTeamComponent")
}

model SkillConfig {
  id                     String    @id @default(cuid())
  componentId            String    @unique
  name                   String
  description            String?
  skillType              SkillType
  argumentHint           String?
  disableModelInvocation Boolean   @default(false)
  userInvocable          Boolean   @default(true)
  allowedTools           String?
  context                String?
  content                String    @default("")
  input                  String    @default("")
  output                 String    @default("")

  component   Component    @relation(fields: [componentId], references: [id], onDelete: Cascade)
  agentConfig AgentConfig?
}

model AgentConfig {
  id              String  @id @default(cuid())
  skillConfigId   String  @unique
  model           String?
  tools           String?
  disallowedTools String?
  permissionMode  String?
  hooks           String?
  memory          String?
  content         String  @default("")

  skillConfig SkillConfig @relation(fields: [skillConfigId], references: [id], onDelete: Cascade)
}

model ComponentFile {
  id          String            @id @default(cuid())
  componentId String
  role        ComponentFileRole
  filename    String
  content     String
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  component          Component           @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([componentId, filename])
}

model AgentTeamMember {
  id                   String @id @default(cuid())
  agentTeamComponentId String
  componentId          String
  sortOrder            Int    @default(0)

  agentTeamComponent Component @relation("AgentTeamComponent", fields: [agentTeamComponentId], references: [id], onDelete: Cascade)
  component          Component @relation("MemberComponent", fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([agentTeamComponentId, componentId])
}

model ComponentDependency {
  id       String @id @default(cuid())
  sourceId String
  targetId String
  order    Int    @default(0)

  source Component @relation("DependencySource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Component @relation("DependencyTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
}
