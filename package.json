{
  "name": "@warabi1062/skillsmith",
  "version": "0.0.1",
  "type": "module",
  "description": "Claude Code のスキル設計パターンをスキーマとして形式化し、プラグインを生成するツール",
  "keywords": [
    "claude",
    "claude-code",
    "skill",
    "plugin",
    "cli",
    "generator"
  ],
  "author": "warabi1062 <kohei.2126@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/warabi1062/SkillSmith.git"
  },
  "homepage": "https://github.com/warabi1062/SkillSmith#readme",
  "bugs": {
    "url": "https://github.com/warabi1062/SkillSmith/issues"
  },
  "bin": {
    "skillsmith": "./cli/bin.cjs"
  },
  "files": [
    "dist",
    "cli/bin.cjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "tsup",
    "build:web": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "cli": "tsx cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm build"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "dependencies": {
    "@warabi1062/skillsmith-core": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@react-router/dev": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.3.1",
    "isbot": "^5.1.0",
    "jsdom": "^29.0.1",
    "oxlint": "1.56.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
