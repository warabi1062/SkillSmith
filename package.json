{
  "name": "skillsmith-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SkillSmith workspace root (non-publishable)",
  "repository": {
    "type": "git",
    "url": "https://github.com/warabi1062/SkillSmith.git"
  },
  "homepage": "https://github.com/warabi1062/SkillSmith#readme",
  "bugs": {
    "url": "https://github.com/warabi1062/SkillSmith/issues"
  },
  "scripts": {
    "dev": "pnpm --filter @warabi1062/skillsmith-viewer dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @warabi1062/skillsmith-viewer build",
    "start": "pnpm --filter @warabi1062/skillsmith-viewer start",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "cli": "tsx packages/cli/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "oxlint": "1.56.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
